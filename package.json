{
  "name": "plug",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "mobile:sync": "node --env-file=.env ./node_modules/@capacitor/cli/bin/capacitor sync",
    "mobile:sync:ios": "node --env-file=.env ./node_modules/@capacitor/cli/bin/capacitor sync ios",
    "mobile:open:ios": "node --env-file=.env ./node_modules/@capacitor/cli/bin/capacitor open ios",
    "mobile:run:ios": "node --env-file=.env ./node_modules/@capacitor/cli/bin/capacitor run ios",
    "create-admin": "node scripts/create-admin.mjs",
    "process-payouts": "node scripts/process-payouts.mjs",
    "setup-supabase": "node --env-file=.env scripts/setup-supabase.mjs",
    "github-init": "node --env-file=.env scripts/github-init.mjs"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.19.2",
    "@supabase/supabase-js": "^2.95.3",
    "@vercel/analytics": "^1.6.1",
    "chess.js": "^1.4.0",
    "livekit-client": "^2.17.1",
    "livekit-server-sdk": "^2.15.0",
    "next": "16.1.1",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.12",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "stripe": "^16.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
